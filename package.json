{
  "name": "abs-agg",
  "version": "0.0.3",
  "description": "Metadata provider framework for Audiobookshelf",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && for dir in src/providers/*/; do name=$(basename $dir); mkdir -p dist/providers/$name && cp $dir/config.json dist/providers/$name/ 2>/dev/null; done",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "generate:docs": "tsx src/generateProviderMarkdown.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.3",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.6.2",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsdom": "^28.1.0",
    "zod": "^4.3.6"
  }
}
